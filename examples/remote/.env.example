# Copy to .env and fill in. Never commit the real .env.

# --- AiSEG2 (LAN) ---
AISEG_URL=http://192.168.0.216
AISEG_USER=aiseg
AISEG_PASSWORD=your-digest-password

# --- Public hostname (must match the Cloudflare Tunnel public hostname) ---
MCP_EXTERNAL_URL=https://mcp-aiseg2.example.com

# --- GitHub OAuth App (Authorization callback URL = ${MCP_EXTERNAL_URL}/.auth/github/callback) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Comma-separated GitHub logins allowed to connect (only these users can use the connector).
GITHUB_ALLOWED_USERS=your-github-login

# --- Cloudflare Tunnel token (remotely-managed tunnel routing to http://mcp-auth-proxy:8080) ---
TUNNEL_TOKEN=
